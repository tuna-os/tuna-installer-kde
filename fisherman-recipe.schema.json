{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Fisherman Install Recipe",
  "description": "JSON recipe for the fisherman bootc install backend",
  "type": "object",
  "required": ["disk", "image", "hostname"],
  "properties": {
    "disk": {
      "type": "string",
      "description": "Target block device, e.g. /dev/sda or /dev/nvme0n1"
    },
    "filesystem": {
      "type": "string",
      "enum": ["xfs", "btrfs"],
      "default": "xfs"
    },
    "btrfsSubvolumes": {
      "type": "boolean",
      "default": false
    },
    "encryption": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["none", "luks"],
          "default": "none"
        },
        "passphrase": {
          "type": "string",
          "description": "LUKS passphrase; required when type=luks"
        }
      }
    },
    "image": {
      "type": "string",
      "description": "OCI image reference, e.g. quay.io/fedora/fedora-bootc:43"
    },
    "targetImgref": {
      "type": "string",
      "description": "Override the installed image reference in the bootloader"
    },
    "selinuxDisabled": {
      "type": "boolean",
      "default": true
    },
    "hostname": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9]([a-zA-Z0-9-]*[a-zA-Z0-9])?$",
      "description": "Hostname for the installed system"
    }
  }
}
